  "keyFeatures": [
    "JWT + refresh token authentication with token rotation",
    "Personal exercise catalog with soft-delete (archiving)",
    "Routine (workout template) management with exercise ordering",
    "Real-time workout session tracking with active workout enforcement",
    "Set logging with warmup set support and RPE tracking",
    "Automatic PR detection (weight PR and volume PR per exercise)",
    "1RM estimation using the Epley formula",
    "Training volume calculation per workout and exercise",
    "Historical progression tracking per exercise",
    "Full Docker-based development environment with hot-reload"
  ],
  "publicApiSurface": [
